# SkillGym environment configuration
# Copy this file to .env and fill in secrets before running the CLI.

# === OpenAI / TruLens ===
OPENAI_API_KEY=
TRULENS_JUDGE_MODEL=gpt-4o-mini
TRULENS_JUDGE_INSTRUCTIONS=Score Harbor traces for goal/plan adherence. Return specific critiques.

# === Harbor Docker settings ===
HARBOR_DOCKER_IMAGE=
HARBOR_DOCKER_CMD=docker
HARBOR_WORKSPACE_MOUNT=/workspace
HARBOR_RESULTS_MOUNT=/harbor/artifacts
HARBOR_EXTRA_ENV=  # Comma-separated KEY=VALUE pairs forwarded into the container.

# === GEPA optimizer ===
GEPA_REFLECTION_MODEL=openai/gpt-4o-mini
GEPA_OBJECTIVE=Evolve the SkillGym instructions using Harbor traces and TruLens rationales.
GEPA_MAX_METRIC_CALLS=8
